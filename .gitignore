# Dependencies
node_modules/

# OS files
.DS_Store

# Editor
.idea/
.vscode/
*.swp

# Cursor
.cursor/mcp.json

# Environment / secrets
.env
.env.*
*.pem

# MCP configs — may contain access tokens or internal tooling references
.mcp.json

# Claude Code local settings — contains user-specific paths and plugins
.claude/settings.local.json

# uSpec component-md extraction cache (temp JSONs from extract-* skills)
.uspec-cache/

# Rendered skill artifacts. The platform-neutral source of truth lives in
# `skills/` and `references/` at the repo root; the directories below are
# generated by `npx uspec-skills install` (or the in-repo `uspec-skills render` dev command).
.cursor/skills/
.claude/skills/
.agents/skills/

# CLI build artifacts
packages/cli/dist/
packages/cli/templates/

# Throwaway React scratch project for validating generated component-md specs.
# Not part of the open-source distribution.
component-example/
